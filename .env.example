# AI Model Token
HF_TOKEN=

# --- Ses Formatı Sabitleri ---
DEFAULT_RATE=48000
DEFAULT_CHANNELS=2
FRAME_DURATION_MS=30

# --- Çıktı Ayarları ---
OUTPUT_FILENAME=system_recorded.wav

# --- Sessizlik Algılama ---
SILENCE_LIMIT=35
SHORT_SILENCE_LIMIT=10
SOFT_CHUNK_DURATION_MS=6000
MAX_CHUNK_DURATION_MS=9000
VAD_AGGRESSIVENESS=3
SILERO_THRESHOLD=0.20

# --- AI Model Ayarları ---
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1

# --- Whisper Ayarları ---
WHISPER_LANGUAGE=en
# Ana ses dosyasını kaydetmek için true yapın
SAVE_AUDIO_FILE=False

# --- Diarization Ayarları ---
# Konuşmacı eşleştirme eşiği (0.0 - 1.0)
DIARIZATION_EMBEDDING_THRESHOLD=0.70
# Warm-up süresi (ms) — ilk bu kadar süre embedding toplanır
DIARIZATION_WARMUP_MS=45000

# --- Konuşmacı Takip Ayarları (Aday Tamponu) ---
# Yeni bir konuşmacı oluşturulmadan önce gereken minimum gözlem sayısı
CANDIDATE_CONFIRMATIONS_NEEDED=2
# Onaylanmayan aday konuşmacıların silinmeden önce bekletileceği döngü (chunk) sayısı
CANDIDATE_TTL=5
# Aday seslerin kendi aralarındaki minimum kosinüs benzerliği eşiği (0.0 - 1.0)
CANDIDATE_SELF_SIMILARITY=0.60