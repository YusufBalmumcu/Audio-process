# Hugging Face token is required for gated Pyannote models.
HF_TOKEN=

# Audio capture defaults. The detected device rate/channels override these at runtime.
DEFAULT_RATE=48000
DEFAULT_CHANNELS=2
FRAME_DURATION_MS=30

# Output behavior.
SAVE_AUDIO_FILE=false
OUTPUT_FILENAME=system_recorded.wav

# Voice activity detection and chunking.
VAD_AGGRESSIVENESS=1
SILERO_THRESHOLD=0.25
SILENCE_LIMIT=30
SHORT_SILENCE_LIMIT=15
SOFT_CHUNK_DURATION_MS=5000
MAX_CHUNK_DURATION_MS=10000

# Model and transcription behavior.
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
WHISPER_LANGUAGE=en
DIARIZATION_EMBEDDING_THRESHOLD=0.75
DIARIZATION_WARMUP_MS=45000
