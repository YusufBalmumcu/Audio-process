# AI Model Token
HF_TOKEN=

# --- Ses Formatı Sabitleri ---
DEFAULT_RATE=48000
DEFAULT_CHANNELS=2
FRAME_DURATION_MS=30

# --- Çıktı Ayarları ---
OUTPUT_FILENAME=system_recorded.wav

# --- Sessizlik Algılama ---
SILENCE_LIMIT=35
SHORT_SILENCE_LIMIT=10
SOFT_CHUNK_DURATION_MS=6000
MAX_CHUNK_DURATION_MS=9000
VAD_AGGRESSIVENESS=3
SILERO_THRESHOLD=0.20

# --- AI Model Ayarları ---
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1

# --- Whisper Ayarları ---
WHISPER_LANGUAGE=en
# Ana ses dosyasını kaydetmek için true yapın
SAVE_AUDIO_FILE=False

# --- Diarization Ayarları ---
# Konuşmacı eşleştirme eşiği (0.0 - 1.0) — ANA AYAR KNOBU.
# Belirsizlik bandı kaldırıldıktan sonra bu, eşleşme ile yeni-aday arasındaki
# TEK kesim noktası. DÜŞÜK eşik → daha çok ses baskın konuşmacıya yapışır
# (over-collapse, AMI'deki kusur). YÜKSEK eşik → aynı konuşmacı bölünebilir
# (over-segmentation). 0.66 dengeli başlangıç; AMI/score.py ile kalibre et:
# DER "confusion" yüksekse ↑, konuşmacı sayısı şişiyorsa ↓.
DIARIZATION_EMBEDDING_THRESHOLD=0.66
# Warm-up süresi (ms) — ilk bu kadar süre embedding toplanır ve konuşmacı
# sayısı belirlenir. UZUN warm-up, başta fazla/gürültülü konuşmacı kümeleyip
# bu sayıyı kalıcı kilitleme riskini artırır. 45sn→20sn'ye indirildi; ayrıca
# _merge_similar_speakers şişen sayıyı sonradan da düzeltir.
DIARIZATION_WARMUP_MS=20000

# --- Konuşmacı Takip Ayarları (Aday Tamponu) ---
# Yeni bir konuşmacı oluşturulmadan önce gereken minimum gözlem sayısı
CANDIDATE_CONFIRMATIONS_NEEDED=4
# Onaylanmayan aday konuşmacıların silinmeden önce bekletileceği döngü (chunk) sayısı
CANDIDATE_TTL=8
# Aday seslerin kendi aralarındaki minimum kosinüs benzerliği eşiği (0.0 - 1.0)
# 0.60 fazla gevşekti: farklı kişilerin kısa/gürültülü embedding'leri birleşip
# tek bir hayalet konuşmacı oluşturabiliyordu. 0.78'e yükseltildi.
CANDIDATE_SELF_SIMILARITY=0.78
# Yeni konuşmacı oluşturabilmek için gereken minimum temiz konuşma süresi (sn).
# Kısa sesler ("evet", "aynen öyle") asla yeni konuşmacı yaratamaz;
# en yakın mevcut konuşmacıya atanır.
MIN_NEW_SPEAKER_DURATION=3.0